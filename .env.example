# Copy to .env for local Docker runs only. Do not commit .env.
#
# On Railway, define these as Railway variables instead of using this file.

# Required. Generate with: railclaw token
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token

# Must match Railway Public Networking HTTP Proxy port.
OPENCLAW_GATEWAY_PORT=8080
PORT=8080

# The image listens publicly through Railway's HTTPS proxy. Keep Bonjour off.
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=UTC

# OpenTelemetry is optional.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com/v1/traces
# OTEL_SERVICE_NAME=openclaw-gateway

# Provider/channel secrets are examples only. Store real values in Railway.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_TOKEN=
# SLACK_BOT_TOKEN=

# Optional image customization at build time. Configure these as Railway build
# args when needed rather than committing a custom secret-bearing Dockerfile.
# OPENCLAW_IMAGE=alpine/openclaw:latest
# OPENCLAW_IMAGE_APT_PACKAGES=additional-apt-package
# OPENCLAW_IMAGE_PIP_PACKAGES=additional-python-package
# OPENCLAW_INSTALL_BROWSER=1
# EXTRA_APT_PACKAGES=additional-apt-package
# EXTRA_NPM_PACKAGES=additional-npm-package
# EXTRA_PIP_PACKAGES=
# INSTALL_PLAYWRIGHT_BROWSERS=1 # legacy alias for OPENCLAW_INSTALL_BROWSER
